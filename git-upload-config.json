{
    "ignore_patterns": [
        "**__pycache__/",
        "**backup/",
        "**git_upload/",
        "**models/",
        "**.log",
        "**temp/",
        "**.env",
        "**.pyc",
		"**.gguf",
        "**.DS_Store",
        "**node_modules/",
		"**.git-upload-cache.json",
		"**.prettierignore",
        "**venv/",
        "/webui/.gitignore",
		"/server/.gitignore",
        "**.github/",
        "**.vscode/",
        "**.idea/",
		"**llama_cpp/",
		"/server/llama_cpp/",
		"**README.md",
		"*data/*",
        "**env/"
    ],
    "default_branch": "main",
    "remote_name": "origin",
    "large_file_limit_mb": 100,
    "ask_for_message": true,
    "auto_commit_message": "🤖 Auto commit on {date}"
}